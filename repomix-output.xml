                                </span>
                                <span v-else class="text-muted small">-</span>
                            </div>
                            <div class="text-muted small" v-if="getShareAmount(owner.id, target.id) > 0">
                                ƒ {{ (getShareAmount(owner.id, target.id) * target.stock_price).toLocaleString() }}
